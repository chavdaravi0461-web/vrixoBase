# ─────────────────────────────────────────────────────
# VrixoBase — Vercel Environment Variables
# Copy these to your Vercel project dashboard:
#   https://vercel.com/YOUR-TEAM/vrixobase/settings/environment-variables
# ─────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=https://vrixo-base-frontend.vercel.app
NEXT_PUBLIC_APP_NAME=VrixoBase

# Backend API — point to your deployed NestJS backend
# (Vercel cannot host the NestJS backend; deploy separately on Render/Railway/Fly.io)
# Leave NEXT_PUBLIC_API_URL unset — Vercel rewrites /api/* to the backend in vercel.json
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=wss://vrixobase-api.onrender.com

# Auth — update redirect URLs to match your Vercel deployment domain
NEXT_PUBLIC_AUTH_REDIRECT=/dashboard
NEXT_PUBLIC_AUTH_GOOGLE_REDIRECT=https://vrixo-base-frontend.vercel.app/auth/callback
NEXT_PUBLIC_AUTH_GITHUB_REDIRECT=https://vrixo-base-frontend.vercel.app/auth/callback

# Storage — point to your S3-compatible storage endpoint
NEXT_PUBLIC_STORAGE_URL=https://vrixobase-api.onrender.com
NEXT_PUBLIC_MINIO_ENDPOINT=vrixobase-api.onrender.com
NEXT_PUBLIC_MINIO_USE_SSL=true

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Features
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_FUNCTIONS=true
