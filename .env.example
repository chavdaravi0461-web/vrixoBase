# VrixoBase Environment Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
# When using docker-compose: postgresql://vrixo:vrixo_secret@localhost:5433/vrixo
DATABASE_URL=postgresql://vrixo:vrixo_secret@localhost:5432/vrixo

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=vrixo-dev

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ──────────────────────────────────────────────
# MinIO (S3-compatible Storage)
# ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=vrixo_admin
MINIO_SECRET_KEY=vrixo_minio_secret
MINIO_BUCKET=vrixo-storage
MINIO_USE_SSL=false

# ──────────────────────────────────────────────
# Security / Encryption
# ──────────────────────────────────────────────
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=change-me-32-char-encryption-key
ENCRYPTION_SALT=change-me-salt-min-8-chars
SESSION_SECRET=change-me-session-secret-min-16

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ──────────────────────────────────────────────
# Realtime / CDC (WAL)
# ──────────────────────────────────────────────
REALTIME_PUBLICATION=vrixobase_realtime
REALTIME_SLOT=vrixobase_cdc_slot
# Start LSN to resume from (leave empty to start from latest)
# REALTIME_START_LSN=0/0

# ──────────────────────────────────────────────
# OAuth - Google (optional)
# ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ──────────────────────────────────────────────
# OAuth - GitHub (optional)
# ──────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ──────────────────────────────────────────────
# AI (optional)
# ──────────────────────────────────────────────
# OPENAI_API_KEY=sk-proj-...
# AI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────
# Frontend (Next.js)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_WS_URL=ws://localhost:4000
