# VrixoBase Environment Variables

# Database
DATABASE_URL=postgresql://vrixo:vrixo_secret@localhost:5432/vrixo

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# MinIO (S3 Compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=vrixo_admin
MINIO_SECRET_KEY=vrixo_minio_secret
MINIO_BUCKET=vrixo-storage
MINIO_USE_SSL=false

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
